# ── Terraform ────────────────────────────────────────────────────────────────

# State files contain sensitive resource IDs and secrets
terraform/terraform.tfstate
terraform/terraform.tfstate.backup

# tfvars contains real IP addresses and SSH keys — copy from terraform.tfvars.example and fill in locally
terraform/terraform.tfvars

# Provider cache — re-downloaded by terraform init
terraform/.terraform/

# Lock files — generated by terraform apply, not needed in git
terraform/.terraform.lock.hcl
terraform/.terraform.tfstate.lock.info

# ── Kubernetes credentials ────────────────────────────────────────────────────

# Admin kubeconfig contains cluster CA and credentials
admin/*.yaml

# ── Generated participant output ──────────────────────────────────────────────

# Everything under participants/ is generated by the provisioning scripts
# and should not be committed — hand files out directly, not via git
participants/*/*

# ── Participants file ─────────────────────────────────────────────────────────

/scripts/participants.txt

# ── Local tooling ─────────────────────────────────────────────────────────────

.claude/
